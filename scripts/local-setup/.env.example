# Local Development Environment Configuration
# Copy this file to .env and adjust values as needed

# Application Environment
APP_ENV=development

# Order Service Database
ORDER_DB_HOST=localhost
ORDER_DB_PORT=5432
ORDER_DB_USER=order_user
ORDER_DB_PASSWORD=order_pass
ORDER_DB_NAME=order_db

# Payment Service Database
PAYMENT_DB_HOST=localhost
PAYMENT_DB_PORT=5433
PAYMENT_DB_USER=payment_user
PAYMENT_DB_PASSWORD=payment_pass
PAYMENT_DB_NAME=payment_db

# Catalog Service Database
CATALOG_DB_HOST=localhost
CATALOG_DB_PORT=5434
CATALOG_DB_USER=catalog_user
CATALOG_DB_PASSWORD=catalog_pass
CATALOG_DB_NAME=catalog_db

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_SCHEMA_REGISTRY=http://localhost:8081

# Redis
REDIS_ADDR=localhost:6379

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
JAEGER_UI=http://localhost:16686
PROMETHEUS_UI=http://localhost:9090
GRAFANA_UI=http://localhost:3000

# Service Ports
ORDER_SERVICE_PORT=8082
PAYMENT_SERVICE_PORT=8083
CATALOG_SERVICE_PORT=8084
